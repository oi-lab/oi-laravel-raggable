{
    "name": "oi-lab/oi-laravel-raggable",
    "description": "Make any Eloquent model semantically searchable: a pluggable embedder and vector store turn model content into embeddings for similarity search and RAG retrieval.",
    "type": "library",
    "keywords": [
        "laravel",
        "raggable",
        "embeddings",
        "vector-search",
        "similarity",
        "pgvector",
        "rag",
        "ai"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "OI Lab",
            "email": "olivier@olacombe.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/bus": "^12.0|^13.0",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/queue": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "laravel/ai": "^0.7|^0.8",
        "oi-lab/oi-laravel-ai": "^1.0",
        "oi-lab/oi-laravel-settings": "^1.0",
        "spatie/laravel-data": "^4.23"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "suggest": {
        "pgvector/pgvector": "Native Postgres pgvector storage with HNSW indexes for the 'pgvector' driver (recommended at scale)."
    },
    "autoload": {
        "psr-4": {
            "OiLab\\OiLaravelRaggable\\": "src/",
            "OiLab\\OiLaravelRaggable\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OiLab\\OiLaravelRaggable\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OiLab\\OiLaravelRaggable\\OiLaravelRaggableServiceProvider"
            ]
        },
        "oi-lab": {
            "skills": [
                {
                    "name": "oilab-laravel-raggable",
                    "description": "Make any Eloquent model semantically searchable: a pluggable embedder and vector store turn model content into embeddings for similarity search and RAG retrieval.",
                    "path": "resources/stubs/ai-skill.md",
                    "rules": "resources/stubs/claude-rules.md",
                    "section": "oi-lab/oi-laravel-raggable rules"
                }
            ]
        }
    },
    "scripts": {
        "sync-ai-skills": [
            "@php scripts/sync-ai-skills.php"
        ],
        "post-autoload-dump": [
            "@php scripts/sync-ai-skills.php"
        ],
        "test": [
            "@php vendor/bin/pest"
        ],
        "lint": [
            "@php vendor/bin/pint"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
